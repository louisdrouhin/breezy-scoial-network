# ============================================================
# BREEZY - Environment Variables
# ============================================================
# Copy this file to .env (dev) or .env.prod (prod)
# and fill in the values for your environment

# ============================================================
# Authentication & Security
# ============================================================
# JWT_SECRET: Used to sign/verify access tokens
# Generate with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=15m

# SALT_ROUNDS: Bcrypt rounds for password hashing (higher = more secure but slower)
# 10 = good balance, 12+ = very secure but slower login
SALT_ROUNDS=10

# INTERNAL_SECRET: Shared secret for inter-service calls (post/user/notif/feed).
# Sent as a header and checked by the receiving service's internal middleware.
# Generate with: openssl rand -base64 32
INTERNAL_SECRET=change_me_internal_secret

# ============================================================
# PostgreSQL Services
# ============================================================
# Auth Service Database
AUTH_DB_USER=postgres
AUTH_DB_PASSWORD=postgres

# User Service Database
USER_DB_USER=postgres
USER_DB_PASSWORD=postgres

# ============================================================
# MongoDB Services
# ============================================================
# Post Service Database
POST_MONGO_USERNAME=admin
POST_MONGO_PASSWORD=admin

# Notification Service Database
NOTIF_MONGO_USERNAME=admin
NOTIF_MONGO_PASSWORD=admin

# ============================================================
# External APIs
# ============================================================
# Klipy API key used only by post-svc to proxy GIF search.
KLIPY_API_KEY=your_klipy_api_key_here

# ============================================================
# Frontend
# ============================================================
# API URL for frontend (update based on your deployment)
NEXT_PUBLIC_API_URL=http://localhost

# NGINX_URL: gateway URL used by the frontend server-side routes
# (e.g. /api/auth/login) to reach the backend from inside the Docker network
NGINX_URL=http://nginx

# ============================================================
# Inter-service URLs (internal Docker network)
# ============================================================
# These are used by services to call each other
# In Docker, use service names; on local, update as needed
USER_SVC_URL=http://user-svc:3002
POST_SVC_URL=http://post-svc:3003
NOTIF_SVC_URL=http://notif-svc:3004
FEED_SVC_URL=http://feed-svc:3005
