// ==========================================================
// post-svc — schema.prisma
// Moteur : MongoDB (NoSQL)
//
// Choix NoSQL explicitement aligné avec le prosit API (doc 04) :
// "développer un prototype d'un service back-end exposant une
// API REST qui utilisera MongoDB [...] L'accès aux données se
// fera via l'ODM Mongoose" -> ici on utilise Prisma comme
// alternative ORM-like mais le moteur reste MongoDB.
//
// Justification fonctionnelle :
//   - volume d'écriture élevé (posts, likes, commentaires)
//   - structure semi-flexible (tags -> Fx12)
//
// MODÈLE UNIFIÉ (façon Twitter/X) :
// Un commentaire est un Post comme un autre, simplement doté
// d'un parentId. Ça couvre nativement Fx7 (commenter un post)
// ET Fx8 (répondre à un commentaire) sans dupliquer d'entité :
// répondre à un commentaire revient juste à créer un Post dont
// le parent est ce commentaire -> profondeur de thread illimitée.
// ==========================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
}

model Post {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // Clé de cohérence partagée : on stocke le username de
  // l'auteur (pas de FK cross-service possible avec MongoDB
  // + pattern database-per-service).
  authorUsername String @map("author_username")

  content String @db.String // Fx3 : 280 caractères max (validation applicative)

  tags String[] // Fx12 : tags pour catégorisation (Fx13 : recherche)

  // null = post racine (Fx3). Renseigné = commentaire/réponse
  // (Fx7, Fx8), peu importe la profondeur du thread.
  parent   Post?   @relation("Replies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  parentId String? @map("parent_id") @db.ObjectId
  replies  Post[]  @relation("Replies")

  likeCount  Int @default(0) @map("like_count")
  replyCount Int @default(0) @map("reply_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  likes Like[]

  @@map("posts")
}

model Like {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // Clé de cohérence : qui a liké
  username String

  // Fonctionne aussi bien pour liker un post racine qu'un
  // commentaire, puisque les deux sont des Post.
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String @map("post_id") @db.ObjectId

  createdAt DateTime @default(now()) @map("created_at")

  // Un utilisateur ne peut liker qu'une fois le même post
  @@unique([username, postId])
  @@map("likes")
}
