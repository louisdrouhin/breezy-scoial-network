// ==========================================================
// user-svc — schema.prisma
// Moteur : PostgreSQL (SQL)
//
// Rôle du service : profils utilisateurs + relations de follow.
//
// Choix SQL justifié par :
//   - le graphe de follow est un many-to-many classique
//     (table de jointure Follow), parfaitement modélisé en
//     relationnel, avec contraintes d'unicité fortes
//     (impossible de suivre 2x la même personne)
//   - les données de profil sont structurées et stables
//
// La clé primaire "username" est répliquée ici (pas de FK
// technique vers auth-svc : chaque service est indépendant
// en MSA, "database per service"). La cohérence est assurée
// applicativement par l'API Gateway / auth-svc qui garantit
// l'unicité du username à la création du compte.
// ==========================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  // Clé de cohérence partagée entre tous les microservices.
  // Immuable (non modifiable après création du compte).
  username String @id @db.VarChar(30)

  displayName String? @map("display_name") @db.VarChar(50)
  bio         String? @db.VarChar(160) // Fx10 : biographie courte
  avatarUrl   String? @map("avatar_url")
  bannerUrl   String? @map("banner_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Fx9 : relations de follow (graphe dirigé)
  following Follow[] @relation("Following")
  followers Follow[] @relation("Followers")

  @@map("profiles")
}

// Table de jointure explicite plutôt qu'une relation implicite
// Prisma : on a besoin du createdAt (date de follow) et ça
// reste plus lisible/évolutif (ex: ajout d'un statut "muted").
model Follow {
  follower         Profile @relation("Following", fields: [followerUsername], references: [username], onDelete: Cascade)
  followerUsername String  @map("follower_username") @db.VarChar(30)

  followed         Profile @relation("Followers", fields: [followedUsername], references: [username], onDelete: Cascade)
  followedUsername String  @map("followed_username") @db.VarChar(30)

  createdAt DateTime @default(now()) @map("created_at")

  @@id([followerUsername, followedUsername])
  @@map("follows")
}
