generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserProfile {
  id        Int     @id @default(autoincrement())
  userId    Int     @unique
  username  String  @unique
  bio       String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Follow {
  id        Int     @id @default(autoincrement())
  followerId Int
  followingId Int
  createdAt DateTime @default(now())

  @@unique([followerId, followingId])
}
