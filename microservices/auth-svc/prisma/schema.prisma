// ==========================================================
// auth-svc — schema.prisma
// Moteur : PostgreSQL (SQL)
//
// Rôle du service : gérer exclusivement l'authentification.
// Ce service NE stocke PAS le profil utilisateur (bio, avatar,
// followers...) -> c'est la responsabilité de user-svc.
//
// Le username est la clé de cohérence inter-services :
//   - immuable une fois créé (non modifiable)
//   - unique
//   - utilisé comme identifiant fonctionnel partagé par
//     auth-svc, user-svc, post-svc, notifs-svc, feed-svc
// ==========================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

model Account {
  // Clé de cohérence partagée entre tous les microservices.
  // Immuable après création. Sert ICI de clé primaire :
  // pas d'UUID séparé, pour ne pas dupliquer la notion
  // d'identité utilisateur.
  username String @id @db.VarChar(30)

  email        String @unique @db.VarChar(255)
  passwordHash String @map("password_hash")

  role   Role    @default(USER)
  active Boolean @default(true) // false si suspendu/banni (Fx21)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  refreshTokens RefreshToken[]

  @@map("accounts")
}

// Logout = simple suppression de la ligne correspondante.
// Pas de champ d'état à gérer : si le token n'existe plus
// en base, le refresh échoue naturellement.
// Un id technique UUID a du sens ici : un compte peut avoir
// plusieurs refresh tokens actifs (multi-appareils), donc ce
// n'est pas une entité "utilisateur" mais une entité technique.
model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  account         Account @relation(fields: [accountUsername], references: [username], onDelete: Cascade)
  accountUsername String  @map("account_username") @db.VarChar(30)

  @@map("refresh_tokens")
}
